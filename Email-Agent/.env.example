# Groq API
GROQ_API_KEY=your_groq_api_key_here

# n8n Configuration
N8N_WEBHOOK_URL=http://localhost:5678/webhook/voice-agent
N8N_API_KEY=your_n8n_api_key_here

# Gmail SMTP (Nodemailer - App Password)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Gmail OAuth2 (for n8n Gmail node - optional)
GMAIL_CLIENT_ID=your_google_client_id
GMAIL_CLIENT_SECRET=your_google_client_secret
GMAIL_REDIRECT_URI=http://localhost:5678/rest/oauth2-credential/callback

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Backend
PORT=3001
NODE_ENV=development
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Frontend
REACT_APP_API_URL=http://localhost:3001
REACT_APP_N8N_WEBHOOK_URL=http://localhost:5678/webhook/voice-agent
