# Groq API (Required — AI chat)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ElevenLabs TTS (Optional — realistic AI voices)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Gmail SMTP (Required — email sending)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Twilio WhatsApp (Required — WhatsApp sending)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Backend Config
PORT=3001
NODE_ENV=production
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Frontend URL (CORS — set to your Vercel frontend URL)
FRONTEND_URL=https://your-frontend.vercel.app

# n8n (Optional)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/voice-agent
N8N_API_KEY=your_n8n_api_key_here
